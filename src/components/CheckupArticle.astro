---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import doctorData from '../../data/doctor.json';
import socialsData from '../../data/socials.json';
import CtaBlock from './CtaBlock.astro';
import RelatedLinks from './RelatedLinks.astro';

export interface Props {
  title: string;
  description: string;
  breadcrumbName: string;
  datePublished?: string;
  dateModified?: string;
  readingTime?: number;
  headings?: { id: string; text: string }[];
  faq?: { question: string; answer: string }[];
  relatedLinks?: { url: string; title: string }[];
}

const {
  title,
  description,
  breadcrumbName,
  datePublished,
  dateModified,
  readingTime,
  headings = [],
  faq = [],
  relatedLinks = [],
} = Astro.props;

const today = new Date().toISOString().split('T')[0];
const pubDate = datePublished || today;
const modDate = dateModified || today;
const canonicalUrl = `https://ortopednn.ru/checkup/${Astro.url.pathname.split('/').filter(Boolean).pop() || ''}/`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: breadcrumbName,
  description,
  author: {
    '@type': 'Person',
    name: doctorData.name,
  },
  publisher: {
    '@type': 'Person',
    name: doctorData.name,
  },
  datePublished: pubDate,
  dateModified: modDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
};
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbTitle={breadcrumbName}
  pageType="article"
  region="Нижний Новгород"
  datePublished={pubDate}
  dateModified={modDate}
  doctor={doctorData}
  socials={socialsData}
>
  <Navbar />
  <main class="page">
    <nav class="breadcrumbs">
      <div class="container">
        <a href="/">Главная</a><span>/</span>
        <a href="/checkup">Самопроверка</a><span>/</span>
        <span>{breadcrumbName}</span>
      </div>
    </nav>

    <article class="content">
      <div class="container">
        <header class="article-header">
          <h1>{breadcrumbName}</h1>
          <div class="article-meta">
            {readingTime && <span class="reading-time">⏱ {readingTime} мин чтения</span>}
            <span class="pub-date">Опубликовано: {pubDate}</span>
            {dateModified && <span class="mod-date">Обновлено: {modDate}</span>}
          </div>
        </header>

        {headings.length > 0 && (
          <nav class="toc">
            <strong>Содержание:</strong>
            <ul>
              {headings.map(h => <li><a href={`#${h.id}`}>{h.text}</a></li>)}
            </ul>
          </nav>
        )}

        <slot />
      </div>
    </article>

    {faq.length > 0 && (
      <div class="container">
        <section class="article-faq">
          <h2>Частые вопросы</h2>
          {faq.map(item => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </section>
      </div>
    )}

    <CtaBlock variant="checkup" />
    {relatedLinks.length > 0 && (
      <div class="container">
        <RelatedLinks links={relatedLinks} />
      </div>
    )}
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <style>
    .page { min-height: 100vh; background: var(--color-bg-alt); }
    .breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
    .breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
    .breadcrumbs a { color: var(--color-primary); }

    .article-header { margin-bottom: var(--space-xl); }
    .article-header h1 { font-size: var(--text-3xl); margin-bottom: var(--space-sm); }
    .article-meta { display: flex; gap: var(--space-md); font-size: var(--text-sm); color: var(--color-text-muted); flex-wrap: wrap; }
    .reading-time { color: var(--color-primary); font-weight: 500; }

    .toc { background: white; border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-lg); margin-bottom: var(--space-2xl); }
    .toc strong { display: block; margin-bottom: var(--space-sm); color: var(--color-text); }
    .toc ul { list-style: none; padding: 0; margin: 0; }
    .toc li { margin-bottom: var(--space-xs); }
    .toc a { color: var(--color-primary); font-size: var(--text-sm); }

    .content { padding: var(--space-3xl) 0; }
    .content .container { max-width: 800px; margin: 0 auto; padding: 0 var(--space-md); }
    .content :global(h1) { font-size: var(--text-3xl); color: var(--color-text); margin-bottom: var(--space-md); }
    .content :global(h2) { font-size: var(--text-2xl); color: var(--color-primary); margin: var(--space-2xl) 0 var(--space-md) 0; }
    .content :global(h3) { font-size: var(--text-lg); color: var(--color-text); margin: var(--space-lg) 0 var(--space-sm) 0; }
    .content :global(p) { color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-md); }
    .content :global(ul) { padding-left: var(--space-lg); margin-bottom: var(--space-md); }
    .content :global(li) { color: var(--color-text-muted); margin-bottom: var(--space-xs); line-height: 1.7; }
    .content :global(.lead) { font-size: var(--text-lg); color: var(--color-text); font-weight: 500; margin-bottom: var(--space-xl); line-height: 1.6; }

    .article-faq { margin: var(--space-3xl) 0; }
    .article-faq h2 { font-size: var(--text-2xl); color: var(--color-primary); margin-bottom: var(--space-lg); }
    .article-faq details { background: white; border: 1px solid var(--color-border); border-radius: var(--radius-lg); margin-bottom: var(--space-sm); overflow: hidden; }
    .article-faq summary { padding: var(--space-md); cursor: pointer; font-weight: 600; color: var(--color-text); }
    .article-faq details p { padding: 0 var(--space-md) var(--space-md); color: var(--color-text-muted); }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-md); }
    @media (max-width: 768px) {
      .article-header h1 { font-size: var(--text-2xl); }
      .article-meta { flex-direction: column; gap: var(--space-xs); }
      .toc { padding: var(--space-md); }
    }
  </style>
</BaseLayout>