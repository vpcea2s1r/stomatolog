---
const pricing = Astro.props.pricing || [];
---

<div x-data="q()" class="quiz">
  <h3>🧮 Расчёт стоимости</h3>
  
  <template x-if="s === 1">
    <div>
      <p>Сколько зубов?</p>
      <button @click="s = 2">1-3 зуба</button>
      <button @click="s = 2">4+</button>
    </div>
  </template>
  
  <template x-if="s === 2">
    <div>
      <p>Тип?</p>
      <template x-for="p in pricing.slice(0, 2)">
        <button @click="s = 3; pr = p.price" x-text="p.name"></button>
      </template>
    </div>
  </template>
  
  <template x-if="s === 3">
    <div>
      <p>Примерно: <strong x-text="new Intl.NumberFormat('ru', {style: 'currency', currency: 'RUB'}).format(pr)"></strong></p>
      <button @click="s = 1">Заново</button>
    </div>
  </template>
</div>

<script>
function q() {
  return {
    s: 1,
    pr: 0
  }
}
</script>

<style>
.quiz {
  background: #f0f9ff;
  padding: 1.5rem;
  border-radius: 12px;
  max-width: 400px;
  margin: 2rem auto;
}
button {
  display: block;
  width: 100%;
  padding: 0.75rem;
  margin: 0.5rem 0;
  background: #e0f2fe;
  border: none;
  border-radius: 8px;
  cursor: pointer;
}
</style>