---
const doctor = Astro.props.doctor;
---

<section class="hero">
  <div class="hero__content">
    <span class="hero__badge">Врач-ортопед, стаж 30+ лет</span>
    <h1 class="hero__title">Протезирование зубов в Нижнем Новгороде</h1>
    <p class="hero__subtitle">Восстановим зубы — от коронки до съёмного протеза. Никитина М.Г., стоматолог-ортопед с 30 летним опытом работы. Бесплатная консультация.</p>
    
    <div class="hero__actions">
      <a href="/checkup/" class="btn btn--primary">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
          <line x1="8" y1="7" x2="16" y2="7"/>
          <line x1="8" y1="11" x2="14" y2="11"/>
        </svg>
        Читать статьи
      </a>
      <a href={`tel:${doctor.phone}`} class="btn btn--secondary">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {doctor.phoneDisplay}
      </a>
    </div>
  </div>
  <div class="hero__decoration" aria-hidden="true">
    <div class="hero__circle hero__circle--1"></div>
    <div class="hero__circle hero__circle--2"></div>
    <div class="hero__circle hero__circle--3"></div>
  </div>
</section>

<style>
.hero {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-bg-alt) 50%, #ede9fe 100%);
  padding: var(--space-3xl) var(--space-md);
  position: relative;
  overflow: hidden;
}

.hero__content {
  max-width: 600px;
  position: relative;
  z-index: 2;
}

.hero__badge {
  display: inline-block;
  background: var(--color-primary);
  color: white;
  padding: var(--space-xs) var(--space-lg);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 600;
  margin-bottom: var(--space-lg);
}

.hero__title {
  font-size: var(--text-4xl);
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: var(--space-sm);
  line-height: 1.1;
}

.hero__subtitle {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  margin-bottom: var(--space-xl);
}

.hero__stats {
  display: flex;
  justify-content: center;
  gap: var(--space-xl);
  margin-bottom: var(--space-xl);
  flex-wrap: wrap;
}

.hero__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 150px;
}

.hero__stat-num {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-primary);
}

.hero__stat-label {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: var(--space-xs);
}

.hero__actions {
  display: flex;
  gap: var(--space-md);
  justify-content: center;
  flex-wrap: wrap;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-lg);
  text-decoration: none;
  font-weight: 600;
  font-size: var(--text-base);
  transition: all var(--transition-fast);
}

.btn--primary {
  background: var(--color-primary);
  color: white;
  box-shadow: var(--shadow-md);
}

.btn--primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 15px 40px rgba(124, 58, 237, 0.4);
}

.btn--secondary {
  background: white;
  color: var(--color-primary);
  border: 2px solid var(--color-border);
}

.btn--secondary:hover {
  background: var(--color-bg);
  border-color: var(--color-primary);
}

.hero__decoration {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

.hero__circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 100%);
  opacity: 0.1;
}

.hero__circle--1 {
  width: 400px;
  height: 400px;
  top: -100px;
  right: -100px;
}

.hero__circle--2 {
  width: 300px;
  height: 300px;
  bottom: -50px;
  left: -100px;
}

.hero__circle--3 {
  width: 200px;
  height: 200px;
  top: 50%;
  right: 20%;
}

@media (min-width: 768px) {
  .hero__title {
    font-size: var(--text-4xl);
  }
}

@media (max-width: 640px) {
  .hero {
    min-height: auto;
    padding: var(--space-xl) var(--space-sm);
  }
  .hero__title {
    font-size: var(--text-2xl);
  }
  .hero__subtitle {
    font-size: var(--text-base);
  }
  .hero__stats {
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }
  .hero__stat {
    min-width: 120px;
  }
  .hero__stat-num {
    font-size: var(--text-base);
  }
  .hero__actions {
    flex-direction: column;
    width: 100%;
  }
  .btn {
    width: 100%;
    justify-content: center;
  }
}
</style>