---
const doctor = Astro.props.doctor;
---

<section class="hero">
  <div class="hero__container">
    <div class="hero__content">
      <span class="hero__badge">Стоматолог-ортопед · с 1994 года</span>
      <h1 class="hero__title">Протезирование<br>зубов в Нижнем Новгороде</h1>
      <p class="hero__subtitle">Коронки, съёмные и бюгельные протезы. Индивидуальный подбор конструкции для каждого клинического случая.</p>
      
      <div class="hero__actions">
        <a href="/services/" class="hero__btn hero__btn--primary">
          Узнать стоимость
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href={`tel:${doctor.phone}`} class="hero__btn hero__btn--outline">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {doctor.phoneDisplay}
        </a>
      </div>

      <div class="hero__trust">
        <span class="hero__trust-item">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5zm-1 15l-4-4 1.41-1.41L11 14.17l6.59-6.59L19 9l-8 8z"/>
          </svg>
          30+ лет опыта
        </span>
        <span class="hero__trust-item">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
          62 вида услуг
        </span>
      </div>
    </div>

    <div class="hero__visual" aria-hidden="true">
      <div class="hero__card">
        <div class="hero__card-icon">🦷</div>
        <div class="hero__card-content">
          <span class="hero__card-title">Бесплатная консультация</span>
          <span class="hero__card-desc">Подберём оптимальный вариант протезирования</span>
        </div>
      </div>
      <div class="hero__card hero__card--offset">
        <div class="hero__card-icon">⚡</div>
        <div class="hero__card-content">
          <span class="hero__card-title">Современные материалы</span>
          <span class="hero__card-desc">Цирконий, E-MAX, AcryFree</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  background: linear-gradient(180deg, var(--color-bg-gradient-start) 0%, var(--color-bg) 100%);
  padding: var(--space-4xl) 0 var(--space-3xl);
  position: relative;
  overflow: hidden;
}

.hero__container {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 0 var(--space-lg);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3xl);
  align-items: center;
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  background: var(--color-primary-1);
  color: var(--color-primary-8);
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: 600;
  margin-bottom: var(--space-lg);
}

.hero__title {
  font-size: var(--text-5xl);
  font-weight: 800;
  color: var(--color-text);
  line-height: var(--leading-tight);
  margin: 0 0 var(--space-md);
  letter-spacing: -0.02em;
}

.hero__subtitle {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  line-height: var(--leading-relaxed);
  margin: 0 0 var(--space-xl);
  max-width: 500px;
}

.hero__actions {
  display: flex;
  gap: var(--space-md);
  flex-wrap: wrap;
  margin-bottom: var(--space-xl);
}

.hero__btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-xl);
  border-radius: var(--radius-full);
  text-decoration: none;
  font-weight: 600;
  font-size: var(--text-base);
  transition: all var(--transition-fast);
}

.hero__btn--primary {
  background: var(--color-primary);
  color: white;
  box-shadow: var(--shadow-primary);
}

.hero__btn--primary:hover {
  background: var(--color-primary-hover);
  box-shadow: 0 8px 24px rgba(22, 119, 255, 0.35);
  transform: translateY(-2px);
  text-decoration: none;
}

.hero__btn--outline {
  background: transparent;
  color: var(--color-text);
  border: 2px solid var(--color-border);
}

.hero__btn--outline:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: var(--color-primary-1);
  text-decoration: none;
}

.hero__trust {
  display: flex;
  gap: var(--space-lg);
}

.hero__trust-item {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  font-weight: 500;
}

.hero__trust-item svg {
  color: var(--color-success);
  flex-shrink: 0;
}

/* Visual cards */
.hero__visual {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  position: relative;
}

.hero__card {
  display: flex;
  align-items: flex-start;
  gap: var(--space-md);
  padding: var(--space-lg);
  background: var(--color-bg);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-md);
  transition: all var(--transition-normal);
  animation: float 6s ease-in-out infinite;
}

.hero__card--offset {
  margin-left: var(--space-xl);
  animation-delay: -3s;
}

.hero__card:hover {
  box-shadow: var(--shadow-lg);
  border-color: var(--color-primary-3);
}

.hero__card-icon {
  font-size: 2rem;
  width: 3.5rem;
  height: 3.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary-1);
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.hero__card-content {
  display: flex;
  flex-direction: column;
  gap: var(--space-xxs);
}

.hero__card-title {
  font-weight: 700;
  font-size: var(--text-base);
  color: var(--color-text);
}

.hero__card-desc {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

/* Responsive */
@media (max-width: 1024px) {
  .hero__container {
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  .hero__visual {
    order: -1;
    flex-direction: row;
  }

  .hero__card--offset {
    margin-left: 0;
  }

  .hero__title {
    font-size: var(--text-4xl);
  }
}

@media (max-width: 768px) {
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .hero__title {
    font-size: var(--text-3xl);
  }

  .hero__subtitle {
    font-size: var(--text-base);
  }

  .hero__actions {
    flex-direction: column;
  }

  .hero__btn {
    justify-content: center;
    width: 100%;
  }

  .hero__visual {
    flex-direction: column;
  }

  .hero__trust {
    flex-direction: column;
    gap: var(--space-xs);
  }
}

@media (max-width: 480px) {
  .hero__title {
    font-size: var(--text-2xl);
  }

  .hero__card {
    padding: var(--space-md);
  }

  .hero__card-icon {
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.5rem;
  }
}
</style>
