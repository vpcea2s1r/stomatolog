---
const address = "Нижний Новгород, ул. Октябрьской Революции, 43, оф. 316";
const metro = ["Ленинская", "Чкаловская"];
const walkTime = "5 минут";
---

<section class="location">
  <div class="container">
    <h2>Как добраться</h2>
    <div class="location-content">
      <div class="location-map">
        <iframe
          src="https://yandex.ru/map-widget/v1/?um=constructor%3A0&amp;source=constructor&amp;ll=43.141389,56.292778&amp;z=16&amp;pt=43.141389,56.292778,pm2blm"
          width="100%"
          height="300"
          frameborder="0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
        <a href="https://yandex.ru/maps/?text=Нижний+Новгород,+ул.+Октябрьской+Революции,+43" target="_blank" rel="noopener" class="route-btn">
          Проложить маршрут
        </a>
      </div>
      <div class="location-info">
        <div class="location-address">
          <h3>Адрес</h3>
          <p>{address}</p>
        </div>
        <div class="location-transport">
          <h3>Общественный транспорт</h3>
          <div class="transport-item">
            <span class="transport-icon">🚇</span>
            <div>
              <p class="transport-label">Метро</p>
              <p class="transport-value">{metro.join(", ")}</p>
              <p class="transport-note">5 минут пешком</p>
            </div>
          </div>
        </div>
        <div class="location-contact">
          <h3>Запись</h3>
          <p><a href="tel:+79202537317">+7 (920) 253-73-17</a></p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.location {
  padding: var(--space-3xl) 0;
  background: white;
}

.location .container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 var(--space-md);
}

.location h2 {
  text-align: center;
  font-size: var(--text-2xl);
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: var(--space-xl);
}

.location-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xl);
  align-items: start;
}

.location-map {
  background: var(--color-bg);
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 1px solid var(--color-border);
}

.location-map iframe {
  display: block;
}

.route-btn {
  display: block;
  text-align: center;
  padding: var(--space-sm) var(--space-md);
  background: var(--color-primary);
  color: white;
  text-decoration: none;
  font-weight: 600;
  font-size: var(--text-sm);
  transition: background var(--transition-fast);
}

.route-btn:hover {
  background: var(--color-primary-active);
}

.location-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.location-info h3 {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-xs);
}

.location-address p {
  color: var(--color-text-muted);
  font-size: var(--text-sm);
  line-height: 1.6;
}

.location-transport {
  background: var(--color-bg);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  border: 1px solid var(--color-border);
}

.transport-item {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
}

.transport-icon {
  font-size: var(--text-xl);
  flex-shrink: 0;
}

.transport-label {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-bottom: 2px;
}

.transport-value {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text);
}

.transport-note {
  font-size: var(--text-xs);
  color: var(--color-primary);
  font-weight: 500;
  margin-top: 2px;
}

.location-contact {
  background: var(--color-bg-alt);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  border: 1px solid var(--color-border);
}

.location-contact p {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--space-xs);
}

.location-contact a[href^="tel"] {
  color: var(--color-primary);
  text-decoration: none;
  font-weight: 700;
}

@media (max-width: 768px) {
  .location-content {
    grid-template-columns: 1fr;
  }

  .location-map iframe {
    height: 250px;
  }
}
</style>