---
const navLinks = [
  { href: "/services", label: "Услуги" },
  { href: "/checkup", label: "Самопроверка" },
];
---

<nav class="navbar" role="navigation" aria-label="Основная навигация">
  <div class="navbar__container">
    <a href="/" class="navbar__logo">Никитина М.Г.</a>
    <div class="navbar__links">
      {navLinks.map(link => (
        <a href={link.href} class="navbar__link">{link.label}</a>
      ))}
    </div>
    <a href="tel:+79202537317" class="navbar__phone" aria-label="Позвонить">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      Позвонить
    </a>
  </div>
</nav>

<style>
.navbar {
  background: white;
  padding: var(--space-sm) 0;
  box-shadow: var(--shadow-sm);
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
}

.navbar__container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 0 var(--space-md);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.navbar__logo {
  font-weight: 800;
  color: var(--color-text);
  font-size: var(--text-sm);
  text-decoration: none;
}

.navbar__links {
  display: flex;
  gap: var(--space-xl);
}

.navbar__link {
  color: var(--color-text-muted);
  font-weight: 500;
  text-decoration: none;
  font-size: var(--text-sm);
  transition: color var(--transition-fast);
}

.navbar__link:hover {
  color: var(--color-primary);
  text-decoration: none;
}

.navbar__phone {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  background: var(--color-primary);
  color: white;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-md);
  text-decoration: none;
  font-weight: 600;
  font-size: var(--text-sm);
  box-shadow: var(--shadow-md);
  transition: all var(--transition-fast);
}

.navbar__phone:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4);
  text-decoration: none;
}

@media (max-width: 768px) {
  .navbar__links {
    display: none;
  }
}

@media (max-width: 480px) {
  .navbar__logo {
    font-size: var(--text-xs);
  }
  .navbar__phone {
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-xs);
  }
  .navbar__phone svg {
    width: 16px;
    height: 16px;
  }
}
</style>