---
import pricing from '../../data/pricing.json';
---

<section class="pricelist">
  <div class="container">
    <header class="pricelist__header">
      <h2 class="pricelist__title">Цены на протезирование</h2>
      <p class="pricelist__subtitle">Точная стоимость определяется после консультации</p>
    </header>
    
    <div class="pricelist__grid">
      {pricing.map(section => (
        <div class="pricelist__category">
          <h3 class="pricelist__category-title">{section.category}</h3>
          <div class="pricelist__items">
            {section.items.map(item => (
              <a href={item.link} class="pricelist__item">
                <span class="pricelist__item-name">{item.name}</span>
                <span class="pricelist__item-price">{item.price}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="pricelist__cta">
      <a href="/services/" class="pricelist__btn">
        Все услуги и цены
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
.pricelist {
  padding: var(--space-4xl) 0;
  background: var(--color-bg);
}

.pricelist__header {
  text-align: center;
  margin-bottom: var(--space-2xl);
}

.pricelist__title {
  font-size: var(--text-3xl);
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: var(--space-xs);
}

.pricelist__subtitle {
  color: var(--color-text-muted);
  font-size: var(--text-base);
  margin: 0;
}

.pricelist__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-xl);
  margin-bottom: var(--space-2xl);
}

.pricelist__category {
  background: var(--color-bg);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border-light);
  overflow: hidden;
  transition: all var(--transition-normal);
}

.pricelist__category:hover {
  box-shadow: var(--shadow-md);
  border-color: var(--color-border);
}

.pricelist__category-title {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-primary);
  text-transform: uppercase;
  letter-spacing: 0.03em;
  padding: var(--space-md) var(--space-lg);
  background: var(--color-primary-1);
  margin: 0;
}

.pricelist__items {
  padding: var(--space-xs) 0;
}

.pricelist__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) var(--space-lg);
  text-decoration: none;
  transition: background var(--transition-fast);
  gap: var(--space-md);
}

.pricelist__item:not(:last-child) {
  border-bottom: 1px solid var(--color-border-light);
}

.pricelist__item:hover {
  background: var(--color-bg-alt);
  text-decoration: none;
}

.pricelist__item-name {
  color: var(--color-text);
  font-size: var(--text-sm);
  line-height: var(--leading-normal);
  flex: 1;
}

.pricelist__item-price {
  color: var(--color-primary);
  font-weight: 700;
  font-size: var(--text-sm);
  white-space: nowrap;
  flex-shrink: 0;
}

.pricelist__cta {
  text-align: center;
}

.pricelist__btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-xl);
  background: var(--color-primary);
  color: white;
  border-radius: var(--radius-full);
  font-weight: 600;
  font-size: var(--text-base);
  text-decoration: none;
  transition: all var(--transition-fast);
}

.pricelist__btn:hover {
  background: var(--color-primary-hover);
  box-shadow: var(--shadow-primary);
  transform: translateY(-2px);
  text-decoration: none;
}

@media (max-width: 768px) {
  .pricelist__grid {
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .pricelist {
    padding: var(--space-2xl) 0;
  }

  .pricelist__title {
    font-size: var(--text-2xl);
  }
}

@media (max-width: 640px) {
  .pricelist__item {
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    padding: var(--space-sm) var(--space-md);
  }

  .pricelist__item-name {
    font-size: var(--text-sm);
  }

  .pricelist__item-price {
    font-size: var(--text-sm);
  }
}
</style>
