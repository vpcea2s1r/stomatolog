---
const services = [
  { title: "Коронки", desc: "Цирконий, металлокерамика", link: "/services/" },
  { title: "Съёмные протезы", desc: "Акрил, AcryFree, нейлон", link: "/services/" },
  { title: "Бюгельные", desc: "На замках и кламмерах", link: "/services/" },
  { title: "Ремонт", desc: "Коррекция, починка", link: "/services/" },
];
---

<section class="services-section">
  <h2 class="services-section__title">Услуги протезирования зубов</h2>
  <div class="services-section__grid">
    {services.map(item => (
      <a href={item.link} class="services-card">
        <div class="services-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="services-card__title">{item.title}</h3>
        <p class="services-card__desc">{item.desc}</p>
        <span class="services-card__arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
</section>

<style>
.services-section {
  padding: var(--space-3xl) 0;
  background: white;
}

.services-section__title {
  text-align: center;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-primary);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: var(--space-xl);
}

.services-section__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: var(--space-sm);
}

.services-card {
  background: var(--color-bg);
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  text-decoration: none;
  transition: all var(--transition-normal);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  border: 1px solid var(--color-border);
  min-height: 180px;
}

.services-card:hover {
  background: white;
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(124, 58, 237, 0.1);
  border-color: var(--color-primary);
  text-decoration: none;
}

.services-card__icon {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-active) 100%);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-md);
  color: white;
}

.services-card__title {
  color: var(--color-text);
  font-size: var(--text-lg);
  font-weight: 700;
  margin-bottom: var(--space-xs);
}

.services-card__desc {
  color: var(--color-text-muted);
  font-size: var(--text-sm);
  line-height: 1.5;
  margin-bottom: var(--space-md);
  flex-grow: 1;
}

.services-card__arrow {
  color: var(--color-primary);
  font-weight: 700;
  font-size: var(--text-xl);
  transition: transform var(--transition-fast);
  margin-top: auto;
}

.services-card:hover .services-card__arrow {
  transform: translateX(4px);
}

@media (max-width: 640px) {
  .services-section {
    padding: var(--space-xl) 0;
  }
  .services-section__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xs);
  }
  .services-card {
    padding: var(--space-md);
    min-height: 160px;
  }
  .services-card__icon {
    width: 40px;
    height: 40px;
    margin-bottom: var(--space-sm);
  }
  .services-card__title {
    font-size: var(--text-base);
  }
}
</style>