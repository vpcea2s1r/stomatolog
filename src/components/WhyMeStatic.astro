---
const doctor = Astro.props.doctor;
---

<section class="why">
  <div class="container">
    <div class="why-content">
      <div class="why-text">
        <h2>Почему выбирают нас</h2>
        <ul>
          {doctor.utp.map((item, i) => (
            <li>
              <span class="check">{i + 1}</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="why-card">
        <div class="doctor-info">
          <h3>{doctor.name}</h3>
          <p>{doctor.specialty}</p>
          <p class="experience">{doctor.experience}</p>
          <p class="address">{doctor.address}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.why {
  padding: 80px 0;
  background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
}

.why-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
}

@media (max-width: 768px) {
  .why-content {
    grid-template-columns: 1fr;
  }
}

.why-text h2 {
  font-size: 1.75rem;
  margin-bottom: 32px;
  color: #1e293b;
}

.why-text ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.why-text li {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  font-size: 1rem;
  color: #475569;
}

.check {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  background: #0ea5e9;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 14px;
}

.why-card {
  background: white;
  border-radius: 24px;
  padding: 32px;
  box-shadow: 0 20px 40px -8px rgba(0,0,0,0.1);
  text-align: center;
}

.doctor-photo {
  margin-bottom: 20px;
}

.doctor-photo img {
  width: 180px;
  height: 180px;
  border-radius: 50%;
  object-fit: cover;
  border: 4px solid #e0f2fe;
}

.doctor-info h3 {
  font-size: 1.25rem;
  color: #1e293b;
  margin-bottom: 4px;
}

.doctor-info p {
  color: #64748b;
}

.doctor-info .experience {
  color: var(--color-primary);
  font-weight: 600;
  margin-top: 8px;
}

.doctor-info .address {
  color: var(--color-text-muted);
  font-size: var(--text-sm);
  margin-top: var(--space-sm);
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 16px;
}
</style>