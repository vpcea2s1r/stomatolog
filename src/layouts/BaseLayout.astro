      "addressLocality": "Нижний Новгород",
      "addressRegion": "Нижегородская область",
      "postalCode": "603000",
      "addressCountry": "RU"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 56.294,
      "longitude": 43.936
    },
