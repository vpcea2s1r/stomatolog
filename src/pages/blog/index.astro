---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import FAQ from '../../components/FAQ.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';

const articles = [
  { slug: 'patologicheskaya-stiraemost-zubov-lechenie', title: 'Патологическая стираемость зубов: современные методы восстановления', date: '2026-05-25', desc: 'Причины патологической стираемости, диагностика, этапы лечения. Протоколы восстановления стёртых зубов.' },
  { slug: 'nejlon-acrifree-akril-kakoj-luchshe', title: 'Нейлон, AcryFree или акрил — какой съёмный протез лучше', date: '2026-05-24', desc: 'Сравнение нейлоновых, AcryFree и акриловых протезов: материалы, гибкость, эстетика, срок службы.' },
  { slug: 'immediat-protezy-chto-eto-pokazaniya', title: 'Иммедиат-протезы — что это, показания и особенности', date: '2026-05-24', desc: 'Иммедиат-протезы: когда ставят, чем отличаются от обычных, адаптация, сроки.' },
  { slug: 'uhod-za-byugelnym-protezom', title: 'Уход за бюгельным протезом — полное руководство', date: '2026-05-24', desc: 'Ежедневная чистка, ультразвуковые ванночки, замена кламмеров, профессиональная гигиена.' },
  { slug: 'keramicheskie-vkladki-vs-koronki', title: 'Керамические вкладки или коронки — что выбрать', date: '2026-05-24', desc: 'Inlay, onlay или коронка: сравнение по объёму препарирования, прочности и долговечности.' },
  { slug: 'kak-vybrat-material-koronki', title: 'Как выбрать материал коронки — сравнение всех видов', date: '2026-05-24', desc: 'Металлокерамика, цирконий, E-max, золото, композит — таблица по 6 критериям.' },
  { slug: 'ceny-na-protezirovanie-v-nn', title: 'Цены на протезирование зубов в Нижнем Новгороде — обзор', date: '2026-05-24', desc: 'Что влияет на стоимость протезирования: материал, лаборатория, квалификация врача.' },
  { slug: 'srok-sluzhby-protezov', title: 'Срок службы зубных протезов — таблица по материалам', date: '2026-05-24', desc: 'Таблица срока службы коронок, мостов, съёмных и имплантных протезов.' },
  { slug: 'alternativy-syomnym-protezam', title: 'Альтернативы съёмным протезам — современные решения', date: '2026-05-24', desc: 'All-on-4, All-on-6, мосты на имплантах, адгезивные мосты, бюгельные протезы.' },
  { slug: 'protezirovanie-na-implantah', title: 'Протезирование на имплантах — виды, этапы, плюсы и минусы', date: '2026-05-24', desc: 'Одиночная коронка, мост, All-on-4, покрывной протез: сравнение методов.' },
  { slug: 'vremennye-koronki-zachem-nuzhny', title: 'Временные коронки — зачем нужны и почему их нельзя пропускать', date: '2026-05-24', desc: 'Зачем ставят временные коронки, что будет без них, сравнение материалов.' },
  { slug: 'protezirovanie-nizhnikh-zubov-vidy-protezov-i-ikh-sravnenie', title: 'Протезирование нижних зубов: виды протезов и их сравнение', date: '2026-05-23', desc: 'Сравнение видов протезов нижних зубов: фиксированные, съемные, материалы, сроки, стоимость.' },
  { slug: 'care-denture', title: 'Уход за съёмным протезом: полное руководство', date: '2024-03-15', desc: 'Как продлить жизнь протеза и избежать проблем. Проверенные советы.' },
  { slug: 'care-crown', title: 'Уход за коронками: что нужно знать', date: '2024-03-10', desc: 'Правила ухода за циркониевыми и металлокерамическими коронками.' },
  { slug: 'first-visit', title: 'Первый визит к ортопеду: чего ожидать', date: '2024-03-05', desc: 'Как подготовиться к консультации и что спросить у врача.' }
];
---

<BaseLayout 
  title="Блог | Никитина Марина Георгиевна — Стоматолог-ортопед"
  description="Полезные статьи об уходе за зубами, протезировании и стоматологии."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="container">
    <a href="/" class="back">← На главную</a>
    
    <h1>Полезные статьи</h1>
    <p class="intro">Делимся знаниями о протезировании и уходе за зубами.</p>

    <div class="articles">
      {articles.map(article => (
        <a href={`/blog/${article.slug}`} class="article-card">
          <div class="date">{article.date}</div>
          <h2>{article.title}</h2>
          <p>{article.desc}</p>
          <span class="read-more">Читать →</span>
        </a>
      ))}
    </div>

    <FAQ />
  </main>
</BaseLayout>

<style>
.container { max-width: 800px; margin: 0 auto; padding: 2rem 1rem; }
.back { color: var(--primary); margin-bottom: 1rem; display: inline-block; }
h1 { color: #1e3a5f; margin-bottom: 0.5rem; }
.intro { color: #5a7a9a; margin-bottom: 2rem; }
.articles { display: grid; gap: 1.5rem; margin-bottom: 3rem; }
.article-card { background: white; border-radius: 12px; padding: 1.5rem; text-decoration: none; display: block; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
.article-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.12); }
.date { color: #7a9ab8; font-size: 0.85rem; margin-bottom: 0.5rem; }
.article-card h2 { color: #1e3a5f; font-size: 1.25rem; margin-bottom: 0.5rem; }
.article-card p { color: #5a7a9a; margin-bottom: 1rem; line-height: 1.6; }
.read-more { color: #4a90d9; font-weight: 600; }
</style>