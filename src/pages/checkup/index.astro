---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import doctor from '../../../data/doctor.json';
import socials from '../../../data/socials.json';
---

<BaseLayout 
  title="Самодиагностика зубов | Никитина Марина Георгиевна"
  description="Чек-лист для проверки здоровья зубов. Когда пора к стоматологу-ортопеду."
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main class="checkup-page">
    <nav class="breadcrumbs"><div class="container"><a href="/">Главная</a><span>/</span><span>Самопроверка</span></div></nav>
    
    <div class="container">
      <header class="checkup-header">
        <h1>Когда пора к стоматологу?</h1>
        <p>Отметьте пункты, которые относятся к вам — узнаете, нужна ли консультация.</p>
      </header>

      <div class="progress-bar-container">
        <div class="progress-bar">
          <div class="progress-bar__fill" id="progressFill"></div>
        </div>
        <div class="progress-label">
          <span id="checkedCount">0</span> из <span id="totalCount">10</span>
        </div>
      </div>

      <div class="checklist">
        <div class="item" data-warning>
          <label class="checkbox-label">
            <input type="checkbox" id="q1">
            <span class="checkmark"></span>
            <span class="item-text">Отсутствуют один или несколько зубов</span>
          </label>
        </div>
        <div class="item" data-warning>
          <label class="checkbox-label">
            <input type="checkbox" id="q2">
            <span class="checkmark"></span>
            <span class="item-text">Зубы шатаются или изменили положение</span>
          </label>
        </div>
        <div class="item">
          <label class="checkbox-label">
            <input type="checkbox" id="q3">
            <span class="checkmark"></span>
            <span class="item-text">Затруднено жевание на определённой стороне</span>
          </label>
        </div>
        <div class="item" data-urgent>
          <label class="checkbox-label">
            <input type="checkbox" id="q4">
            <span class="checkmark"></span>
            <span class="item-text">Боль при накусывании на конкретный зуб</span>
          </label>
        </div>
        <div class="item">
          <label class="checkbox-label">
            <input type="checkbox" id="q5">
            <span class="checkmark"></span>
            <span class="item-text">Старые коронки потемнели или шатаются</span>
          </label>
        </div>
        <div class="item" data-warning>
          <label class="checkbox-label">
            <input type="checkbox" id="q6">
            <span class="checkmark"></span>
            <span class="item-text">Дёсны кровоточат при чистке</span>
          </label>
        </div>
        <div class="item">
          <label class="checkbox-label">
            <input type="checkbox" id="q7">
            <span class="checkmark"></span>
            <span class="item-text">Носите съёмный протез более 5 лет</span>
          </label>
        </div>
        <div class="item" data-warning>
          <label class="checkbox-label">
            <input type="checkbox" id="q8">
            <span class="checkmark"></span>
            <span class="item-text">Протез стал натирать или плохо фиксируется</span>
          </label>
        </div>
        <div class="item" data-warning>
          <label class="checkbox-label">
            <input type="checkbox" id="q9">
            <span class="checkmark"></span>
            <span class="item-text">Изменился прикус или форма лица</span>
          </label>
        </div>
        <div class="item" data-urgent>
          <label class="checkbox-label">
            <input type="checkbox" id="q10">
            <span class="checkmark"></span>
            <span class="item-text">Челюсть щёлкает или болит при открывании</span>
          </label>
        </div>
      </div>

      <div class="result-block" id="resultBlock">
        <div class="result-header">
          <div class="result-icon" id="resultIcon"></div>
          <div class="result-status" id="resultStatus">Результат</div>
        </div>
        <div class="result-text" id="resultText">
          Отметьте пункты выше, чтобы узнать результат.
        </div>
        <div class="result-actions" id="resultActions" style="display:none;">
          <a href={`tel:${doctor.phone}`} class="btn btn--primary">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Позвонить
          </a>
        </div>
      </div>

      <div class="info-grid">
        <div class="info-card">
          <div class="info-card__value">97%</div>
          <div class="info-card__label">Пациенты с потерей более 5 зубов нуждаются в протезировании для восстановления функции.</div>
        </div>
        <div class="info-card">
          <div class="info-card__value">5-7 лет</div>
          <div class="info-card__label">Средний срок службы съёмного протеза (International Journal of Prosthodontics)</div>
        </div>
      </div>

      <section class="articles-section">
        <div class="container">
          <h2>Полезные статьи</h2>
          <div class="articles-grid">
            <a href="/checkup/bolit-zub-pod-koronkoj" class="article-card">
              <h3>Болит зуб под коронкой — что делать?</h3>
              <p>Причины боли, домашняя помощь, варианты лечения.</p>
            </a>
            <a href="/checkup/koronka-na-zub-cena" class="article-card">
              <h3>Сколько стоит коронка на зуб?</h3>
              <p>Цены на металлокерамику, цирконий, цельнолитые коронки в НН.</p>
            </a>
            <a href="/checkup/byugelnyj-protez-cena" class="article-card">
              <h3>Бюгельный протез — цена</h3>
              <p>Кламмерные и замковые конструкции. Сравнение с другими протезами.</p>
            </a>
            <a href="/checkup/metallokeramika-cena" class="article-card">
              <h3>Металлокерамическая коронка — цена</h3>
              <p>Стоимость, показания, сравнение с цирконием.</p>
            </a>
            <a href="/checkup/cirkonievaya-koronka" class="article-card">
              <h3>Циркониевая коронка — цена</h3>
              <p>Преимущества циркония, срок службы, стоимость.</p>
            </a>
            <a href="/checkup/semnyj-protez-cena" class="article-card">
              <h3>Съёмный протез — цены в НН</h3>
              <p>Акриловые, нейлоновые, AcryFree. Сравнение материалов.</p>
            </a>
            <a href="/checkup/polnyj-semnyj-protez" class="article-card">
              <h3>Полный съёмный протез — цена</h3>
              <p>Акрил, AcryFree, нейлон. Какой выбрать при полной адентии.</p>
            </a>
            <a href="/checkup/nejlonovyj-protez" class="article-card">
              <h3>Нейлоновый протез — отзывы</h3>
              <p>Плюсы и минусы, сравнение с акрилом, цена.</p>
            </a>
            <a href="/checkup/akrilovyj-protez" class="article-card">
              <h3>Акриловый протез</h3>
              <p>Цена, срок службы, кому подходит.</p>
            </a>
            <a href="/checkup/mostovidnyj-protez-cena" class="article-card">
              <h3>Мостовидный протез — цена</h3>
              <p>Металлокерамика, цирконий, адгезивные мосты.</p>
            </a>
            <a href="/checkup/kakoj-protez-vybrat" class="article-card">
              <h3>Какой протез лучше выбрать</h3>
              <p>Сравнение всех видов протезов по ситуации.</p>
            </a>
            <a href="/checkup/vypala-koronka" class="article-card">
              <h3>Выпала коронка — что делать</h3>
              <p>Первая помощь и когда срочно к врачу.</p>
            </a>
            <a href="/checkup/implantatsiya-cena" class="article-card">
              <h3>Протезирование на имплантах</h3>
              <p>Цены, All-on-4, одиночные коронки на имплантах.</p>
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<script>
  const checkboxes = document.querySelectorAll('input[type="checkbox"]');
  const progressFill = document.getElementById('progressFill');
  const checkedCount = document.getElementById('checkedCount');
  const totalCount = document.getElementById('totalCount');
  const resultBlock = document.getElementById('resultBlock');
  const resultIcon = document.getElementById('resultIcon');
  const resultStatus = document.getElementById('resultStatus');
  const resultText = document.getElementById('resultText');
  const resultActions = document.getElementById('resultActions');

  const total = checkboxes.length;
  totalCount.textContent = total;

  function updateResult() {
    const checked = document.querySelectorAll('input[type="checkbox"]:checked').length;
    const warnings = document.querySelectorAll('.item[data-warning] input:checked').length;
    const urgent = document.querySelectorAll('.item[data-urgent] input:checked').length;

    const percent = (checked / total) * 100;
    progressFill.style.width = percent + '%';
    checkedCount.textContent = checked;

    if (checked === 0) {
      resultBlock.className = 'result-block';
      resultIcon.textContent = '—';
      resultStatus.textContent = 'Результат';
      resultText.textContent = 'Отметьте пункты выше, чтобы узнать результат.';
      resultActions.style.display = 'none';
    } else if (urgent > 0) {
      resultBlock.className = 'result-block result-block--urgent';
      resultIcon.textContent = '⚠';
      resultStatus.textContent = 'Нужна срочная консультация';
      resultText.textContent = 'Отмеченные симптомы требуют незамедлительного осмотра. Не откладывайте визит к стоматологу.';
      resultActions.style.display = 'block';
    } else if (warnings >= 3 || checked >= 6) {
      resultBlock.className = 'result-block result-block--warning';
      resultIcon.textContent = '!';
      resultStatus.textContent = 'Запишитесь на приём';
      resultText.textContent = `${checked} отмеченных пунктов. Чем раньше обратитесь, тем проще и дешевле решить проблему.`;
      resultActions.style.display = 'block';
    } else if (checked >= 3) {
      resultBlock.className = 'result-block result-block--notice';
      resultIcon.textContent = '~';
      resultStatus.textContent = 'Рекомендуем осмотр';
      resultText.textContent = `${checked} отмеченных пункта. Запишитесь на плановую консультацию.`;
      resultActions.style.display = 'block';
    } else {
      resultBlock.className = 'result-block result-block--ok';
      resultIcon.textContent = '✓';
      resultStatus.textContent = 'Всё в порядке';
      resultText.textContent = `${checked} отмеченный пункт. Профилактический осмотр раз в год — хорошая практика.`;
      resultActions.style.display = 'block';
    }
  }

  checkboxes.forEach(cb => {
    cb.addEventListener('change', updateResult);
  });

  checkboxes.forEach(cb => {
    cb.closest('.item').classList.add(cb.checked ? 'item--checked' : '');
    cb.addEventListener('change', () => {
      cb.closest('.item').classList.toggle('item--checked', cb.checked);
    });
  });
</script>

<style>
.checkup-page { min-height: 100vh; background: var(--color-bg); }
.breadcrumbs { padding: var(--space-sm) 0; background: white; border-bottom: 1px solid var(--color-border); }
.breadcrumbs .container { display: flex; gap: var(--space-sm); font-size: var(--text-sm); flex-wrap: wrap; }
.breadcrumbs a { color: var(--color-primary); }
.container { max-width: 700px; margin: 0 auto; padding: var(--space-lg) var(--space-md); }

.checkup-header { text-align: center; margin-bottom: var(--space-xl); }
.checkup-header h1 { font-size: var(--text-2xl); font-weight: 800; color: var(--color-text); margin-bottom: var(--space-xs); }
.checkup-header p { font-size: var(--text-base); color: var(--color-text-muted); }

.progress-bar-container {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
  padding: var(--space-sm) 0;
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
}
.progress-bar { flex: 1; height: 8px; background: var(--color-border); border-radius: 4px; overflow: hidden; }
.progress-bar__fill { height: 100%; background: var(--color-primary); border-radius: 4px; width: 0; transition: width 0.3s; }
.progress-label { font-size: var(--text-sm); color: var(--color-text-muted); white-space: nowrap; }
.progress-label span { font-weight: 700; color: var(--color-text); }

.checklist { display: flex; flex-direction: column; gap: var(--space-xs); margin-bottom: var(--space-xl); }
.item { background: white; border-radius: var(--radius-lg); border: 2px solid transparent; transition: all 0.2s; }
.item--checked { border-color: var(--color-primary); }
.item[data-warning] { background: #fef9c3; }
.item[data-urgent] { background: #fee2e2; }
.item--checked[data-warning] { background: #fef08a; border-color: #eab308; }
.item--checked[data-urgent] { background: #fecaca; border-color: #ef4444; }

.checkbox-label { display: flex; align-items: center; gap: var(--space-md); padding: var(--space-md); cursor: pointer; }
.checkbox-label input { display: none; }
.checkmark { width: 24px; height: 24px; border: 2px solid var(--color-border); border-radius: var(--radius-md); flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: all 0.2s; font-size: 14px; color: transparent; }
.item--checked .checkmark { background: var(--color-primary); border-color: var(--color-primary); color: white; }
.item--checked[data-warning] .checkmark { background: #eab308; border-color: #eab308; }
.item--checked[data-urgent] .checkmark { background: #ef4444; border-color: #ef4444; }
.item-text { font-size: var(--text-base); color: var(--color-text); font-weight: 500; }

.result-block { background: white; border-radius: var(--radius-xl); padding: var(--space-xl); margin-bottom: var(--space-xl); border: 2px solid var(--color-border); transition: all 0.3s; }
.result-block--ok { border-color: #22c55e; background: linear-gradient(to bottom, white, #f0fdf4); }
.result-block--notice { border-color: #eab308; background: linear-gradient(to bottom, white, #fefce8); }
.result-block--warning { border-color: #f97316; background: linear-gradient(to bottom, white, #fff7ed); }
.result-block--urgent { border-color: #ef4444; background: linear-gradient(to bottom, white, #fef2f2); }

.result-header { display: flex; align-items: center; gap: var(--space-md); margin-bottom: var(--space-md); }
.result-icon { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; background: var(--color-bg); }
.result-block--ok .result-icon { background: #dcfce7; color: #22c55e; }
.result-block--notice .result-icon { background: #fef9c3; color: #eab308; }
.result-block--warning .result-icon { background: #ffedd5; color: #f97316; }
.result-block--urgent .result-icon { background: #fee2e2; color: #ef4444; }
.result-status { font-size: var(--text-lg); font-weight: 700; color: var(--color-text); }
.result-text { font-size: var(--text-base); color: var(--color-text-muted); line-height: 1.6; margin-bottom: var(--space-lg); }
.result-actions { display: flex; justify-content: center; }

.btn { display: inline-flex; align-items: center; gap: var(--space-xs); padding: var(--space-sm) var(--space-xl); border-radius: var(--radius-lg); text-decoration: none; font-weight: 600; font-size: var(--text-base); transition: all var(--transition-fast); }
.btn--primary { background: var(--color-primary); color: white; box-shadow: var(--shadow-md); }
.btn--primary:hover { transform: translateY(-2px); box-shadow: 0 15px 40px rgba(124, 58, 237, 0.4); text-decoration: none; }

.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
.info-card { background: white; border-radius: var(--radius-xl); padding: var(--space-lg); border: 1px solid var(--color-border); text-align: center; }
.info-card__value { font-size: var(--text-3xl); font-weight: 800; color: var(--color-primary); }
.info-card__label { font-size: var(--text-xs); color: var(--color-text-muted); margin-top: var(--space-xs); line-height: 1.5; }

@media (max-width: 640px) {
  .checkup-header h1 { font-size: var(--text-xl); }
  .info-grid { grid-template-columns: 1fr; }
  .result-block { padding: var(--space-lg); }
  .btn { width: 100%; justify-content: center; }
  }
  .articles-section { padding-bottom: var(--space-2xl); }
  .articles-section h2 { font-size: var(--text-xl); color: var(--color-text); margin-bottom: var(--space-lg); }
  .articles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
  .article-card { display: block; background: white; border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-lg); text-decoration: none; transition: all var(--transition-fast); }
  .article-card:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(124, 58, 237, 0.1); border-color: var(--color-primary); text-decoration: none; }
  .article-card h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-xs); font-weight: 600; }
  .article-card p { font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-sm); line-height: 1.5; }
  .article-meta { font-size: var(--text-xs); color: var(--color-primary); font-weight: 500; }
  @media (max-width: 640px) {
    .articles-grid { grid-template-columns: 1fr; }
  }
</style>