---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroActive.astro';
import Specializations from '../components/Specializations.astro';
import PriceList from '../components/PriceList.astro';
import FAQ from '../components/FAQ.astro';
import WhyMeStatic from '../components/WhyMeStatic.astro';
import LocationBlock from '../components/LocationBlock.astro';

import doctor from '../../data/doctor.json';
import socials from '../../data/socials.json';
---

<BaseLayout 
  title="Протезирование зубов в Нижнем Новгороде | Никитина М.Г."
  description="Стоматолог-ортопед Никитина М.Г. в Нижнем Новгороде. Протезирование зубов: коронки (металлокерамика, цирконий), съёмные и бюгельные протезы. Запись на приём. Адрес: ул. Октябрьской Революции, д. 43, оф. 316."
  region="Нижний Новгород"
  doctor={doctor}
  socials={socials}
>
  <Navbar />
  <main id="main">
    <HeroSection doctor={doctor}/>

    <section class="intro">
      <div class="container container--narrow">
        <p>Протезирование зубов в Нижнем Новгороде — это восстановление отсутствующих зубов коронками, съёмными или бюгельными протезами. Стоматолог-ортопед Никитина М.Г. принимает пациентов с 1994 года. В своей практике использует металлокерамику, цирконий, современные термопластичные и акриловые протезы — индивидуальный подбор конструкции для каждого клинического случая.</p>
      </div>
    </section>

    <section class="trust-strip">
      <div class="container">
        <div class="trust-strip__grid">
          <div class="trust-strip__item">
            <span class="trust-strip__number">30+</span>
            <span class="trust-strip__label">лет опыта</span>
          </div>
          <div class="trust-strip__item">
            <span class="trust-strip__number">62</span>
            <span class="trust-strip__label">вида услуг</span>
          </div>
          <div class="trust-strip__item">
            <span class="trust-strip__number">1994</span>
            <span class="trust-strip__label">год начала практики</span>
          </div>
          <div class="trust-strip__item">
            <span class="trust-strip__number">∞</span>
            <span class="trust-strip__label">индивидуальный подход</span>
          </div>
        </div>
      </div>
    </section>

    <WhyMeStatic doctor={doctor}/>

    <section class="categories">
      <div class="container">
        <h2 class="categories__title">Направления работы</h2>
        <div class="categories__grid">
          <a href="/services/metallokeramika/" class="category-card">
            <div class="category-card__icon">🦷</div>
            <h3 class="category-card__title">Коронки</h3>
            <p class="category-card__desc">Металлокерамика, цирконий, E-MAX — восстановление формы и эстетики зубов</p>
            <span class="category-card__arrow">→</span>
          </a>
          <a href="/services/sjemny-protez/" class="category-card">
            <div class="category-card__icon">😁</div>
            <h3 class="category-card__title">Съёмные протезы</h3>
            <p class="category-card__desc">Акрил, AcryFree, нейлон — комфортное протезирование при полном отсутствии зубов</p>
            <span class="category-card__arrow">→</span>
          </a>
          <a href="/services/byugelnyj/" class="category-card">
            <div class="category-card__icon">✨</div>
            <h3 class="category-card__title">Бюгельные протезы</h3>
            <p class="category-card__desc">Надёжная фиксация, тонкая металлическая дуга — максимум комфорта</p>
            <span class="category-card__arrow">→</span>
          </a>
          <a href="/checkup/" class="category-card">
            <div class="category-card__icon">🔍</div>
            <h3 class="category-card__title">Самодиагностика</h3>
            <p class="category-card__desc">Узнайте, что делать, если болит зуб под коронкой или протез плохо держится</p>
            <span class="category-card__arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    <PriceList />
    <FAQ />
    <LocationBlock />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="site-footer__grid">
        <div class="site-footer__brand">
          <span class="site-footer__logo">Никитина М.Г.</span>
          <p class="site-footer__subtitle">Стоматолог-ортопед, Нижний Новгород</p>
        </div>
        <div class="site-footer__nav">
          <a href="/services/">Услуги</a>
          <a href="/checkup/">Самодиагностика</a>
          <a href="/compare/">Сравнение</a>
          <a href="/materials/">Материалы</a>
        </div>
        <div class="site-footer__contact">
          <a href="tel:+79202537317" class="site-footer__phone">+7 (920) 253-73-17</a>
          <p>г. Нижний Новгород, ул. Октябрьской Революции, 43, оф. 316</p>
        </div>
      </div>
      <div class="site-footer__bottom">
        <p>© {new Date().getFullYear()} Никитина М.Г. Все права защищены</p>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
/* ===== Intro ===== */
.intro {
  padding: var(--space-3xl) 0;
  background: linear-gradient(180deg, var(--color-bg-gradient-start) 0%, var(--color-bg-gradient-end) 100%);
}

.intro p {
  font-size: var(--text-lg);
  color: var(--color-text);
  line-height: var(--leading-relaxed);
  text-align: center;
}

/* ===== Trust Strip ===== */
.trust-strip {
  padding: var(--space-2xl) 0;
  background: var(--color-bg);
  border-top: 1px solid var(--color-border-light);
  border-bottom: 1px solid var(--color-border-light);
}

.trust-strip__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-lg);
  text-align: center;
}

.trust-strip__item {
  display: flex;
  flex-direction: column;
  gap: var(--space-xxs);
}

.trust-strip__number {
  font-size: var(--text-3xl);
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.trust-strip__label {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}

/* ===== Categories ===== */
.categories {
  padding: var(--space-4xl) 0;
  background: var(--color-bg-alt);
}

.categories__title {
  text-align: center;
  font-size: var(--text-3xl);
  font-weight: 800;
  color: var(--color-text);
  margin-bottom: var(--space-2xl);
}

.categories__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-lg);
}

.category-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding: var(--space-xl);
  background: var(--color-bg);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border-light);
  text-decoration: none;
  color: inherit;
  transition: all var(--transition-normal);
  position: relative;
  overflow: hidden;
  height: 100%;
}

.category-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--color-primary);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform var(--transition-normal);
}

.category-card:hover {
  box-shadow: var(--shadow-lg);
  border-color: var(--color-primary-3);
  transform: translateY(-4px);
}

.category-card:hover::before {
  transform: scaleX(1);
}

.category-card__icon {
  font-size: 2rem;
  width: 3rem;
  height: 3rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary-1);
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.category-card__title {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-text);
  margin: 0;
}

.category-card__desc {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: var(--leading-normal);
  margin: 0;
  flex-grow: 1;
}

.category-card__arrow {
  font-size: var(--text-lg);
  color: var(--color-primary);
  transition: transform var(--transition-normal);
  align-self: flex-end;
  margin-top: var(--space-xs);
}

.category-card:hover .category-card__arrow {
  transform: translateX(4px);
}

/* ===== Footer ===== */
.site-footer {
  background: var(--color-bg-dark);
  padding: var(--space-3xl) 0 var(--space-xl);
  color: rgba(255, 255, 255, 0.8);
}

.site-footer__grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: var(--space-2xl);
  padding-bottom: var(--space-xl);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.site-footer__logo {
  font-weight: 800;
  color: white;
  font-size: var(--text-xl);
  display: block;
  margin-bottom: var(--space-xs);
}

.site-footer__subtitle {
  color: rgba(255, 255, 255, 0.5);
  font-size: var(--text-sm);
  margin: 0;
}

.site-footer__nav {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.site-footer__nav a {
  color: rgba(255, 255, 255, 0.7);
  text-decoration: none;
  font-size: var(--text-sm);
  transition: color var(--transition-fast);
}

.site-footer__nav a:hover {
  color: white;
}

.site-footer__contact {
  text-align: right;
}

.site-footer__phone {
  color: white;
  font-size: var(--text-lg);
  font-weight: 700;
  text-decoration: none;
  display: block;
  margin-bottom: var(--space-xs);
  transition: color var(--transition-fast);
}

.site-footer__phone:hover {
  color: var(--color-primary-3);
}

.site-footer__contact p {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.5);
  margin: 0;
}

.site-footer__bottom {
  padding-top: var(--space-lg);
  text-align: center;
}

.site-footer__bottom p {
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.3);
  margin: 0;
}

/* ===== Container ===== */
.container {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 0 var(--space-lg);
}

.container--narrow {
  max-width: var(--container-narrow);
}

/* ===== Responsive ===== */
@media (max-width: 1024px) {
  .categories__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .trust-strip__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .site-footer__grid {
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    text-align: center;
  }

  .site-footer__contact {
    text-align: center;
  }

  .categories__title {
    font-size: var(--text-2xl);
  }

  .trust-strip__number {
    font-size: var(--text-2xl);
  }
}

@media (max-width: 640px) {
  .categories__grid {
    grid-template-columns: 1fr;
  }

  .intro {
    padding: var(--space-2xl) 0;
  }

  .intro p {
    font-size: var(--text-base);
  }

  .categories {
    padding: var(--space-2xl) 0;
  }

  .category-card {
    padding: var(--space-lg);
  }
}
</style>
