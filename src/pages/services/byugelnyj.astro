<ServiceArticle
  title="Бюгельный протез — Никитина М.Г."
  description="Бюгельные зубные протезы в Нижнем Новгороде. Цена от 25000 рублей. Виды, показания, уход за бюгельными протезами."
  breadcrumbName="Бюгельный протез"
  price="от 25 000 ₽"
  priceNumeric={25000}
