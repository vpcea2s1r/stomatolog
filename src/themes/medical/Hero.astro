---
const doctor = Astro.props.doctor;
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__container">
    <div class="hero__content">
      <span class="hero__badge">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
        </svg>
        Стоматолог-ортопед · с 1994 года
      </span>
      <h1 class="hero__title">Протезирование зубов<br/>в Нижнем Новгороде</h1>
      <p class="hero__subtitle">Коронки из циркония и металлокерамики, съёмные и бюгельные протезы. Индивидуальный подход к каждому пациенту.</p>
      
      <div class="hero__actions">
        <a href="/services/" class="hero__btn hero__btn--primary">
          Все услуги
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href={`tel:${doctor.phone}`} class="hero__btn hero__btn--outline">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {doctor.phoneDisplay}
        </a>
      </div>

      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-value">30+</span>
          <span class="hero__stat-label">лет опыта</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-value">62</span>
          <span class="hero__stat-label">вида работ</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-value">100%</span>
          <span class="hero__stat-label">индивидуально</span>
        </div>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__photo-frame">
        <div class="hero__photo">
          <svg viewBox="0 0 400 500" width="100%" height="100%" fill="none" aria-hidden="true">
            <rect width="400" height="500" rx="20" fill="url(#grad)" />
            <circle cx="200" cy="180" r="60" fill="rgba(255,255,255,0.15)"/>
            <ellipse cx="200" cy="380" rx="80" ry="60" fill="rgba(255,255,255,0.1)"/>
            <defs>
              <linearGradient id="grad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="var(--color-primary-3)" />
                <stop offset="100%" stop-color="var(--color-primary-7)" />
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div class="hero__photo-badge">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z"/>
          </svg>
          Бесплатная консультация
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  padding: var(--space-3xl) 0;
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--color-bg) 0%, var(--color-bg-gradient-start) 50%, var(--color-bg) 100%);
  z-index: 0;
}

.hero__bg::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 600px;
  height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(2,132,199,0.04) 0%, transparent 70%);
  pointer-events: none;
}

.hero__container {
  position: relative;
  z-index: 1;
  max-width: var(--container-max);
  margin: 0 auto;
  padding: 0 var(--space-lg);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3xl);
  align-items: center;
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-xs) var(--space-md);
  background: var(--color-primary-1);
  color: var(--color-primary-8);
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: 600;
  margin-bottom: var(--space-lg);
}

.hero__title {
  font-size: var(--text-5xl);
  font-weight: 800;
  color: var(--color-text);
  line-height: 1.15;
  margin: 0 0 var(--space-md);
  letter-spacing: -0.03em;
}

.hero__subtitle {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  line-height: 1.7;
  margin: 0 0 var(--space-xl);
  max-width: 480px;
}

.hero__actions {
  display: flex;
  gap: var(--space-md);
  flex-wrap: wrap;
  margin-bottom: var(--space-xl);
}

.hero__btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-xl);
  border-radius: var(--radius-lg);
  text-decoration: none;
  font-weight: 600;
  font-size: var(--text-base);
  transition: all var(--transition-fast);
}

.hero__btn--primary {
  background: var(--color-primary);
  color: white;
  box-shadow: var(--shadow-primary);
}

.hero__btn--primary:hover {
  background: var(--color-primary-hover);
  transform: translateY(-2px);
  text-decoration: none;
}

.hero__btn--outline {
  background: transparent;
  color: var(--color-text);
  border: 1.5px solid var(--color-border);
}

.hero__btn--outline:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: var(--color-primary-1);
  text-decoration: none;
}

.hero__stats {
  display: flex;
  gap: var(--space-xl);
}

.hero__stat {
  display: flex;
  flex-direction: column;
}

.hero__stat-value {
  font-size: var(--text-2xl);
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.hero__stat-label {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: var(--space-xxs);
}

/* Right side - photo placeholder */
.hero__photo-frame {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero__photo {
  width: 100%;
  max-width: 360px;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.hero__photo-badge {
  position: absolute;
  bottom: var(--space-lg);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-lg);
  background: white;
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text);
  box-shadow: var(--shadow-md);
  white-space: nowrap;
}

.hero__photo-badge svg {
  color: var(--color-success);
}

/* Responsive */
@media (max-width: 1024px) {
  .hero__container {
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }
  .hero__visual {
    order: -1;
  }
  .hero__photo {
    max-width: 280px;
    margin: 0 auto;
  }
  .hero__title {
    font-size: var(--text-4xl);
  }
}

@media (max-width: 768px) {
  .hero { padding: var(--space-2xl) 0; }
  .hero__title { font-size: var(--text-3xl); }
  .hero__subtitle { font-size: var(--text-base); }
  .hero__actions { flex-direction: column; }
  .hero__btn { justify-content: center; width: 100%; }
  .hero__stats { gap: var(--space-lg); }
}

@media (max-width: 480px) {
  .hero__title { font-size: var(--text-2xl); }
  .hero__stats { flex-wrap: wrap; gap: var(--space-md); }
}
</style>
